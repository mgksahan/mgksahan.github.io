# AWS Cognito Integration Config Example
# Copy this file to '.env' to enable real AWS Cognito User Pool authentication.

# The region where your User Pool is located (e.g., us-east-1)
VITE_COGNITO_REGION=us-east-1

# Your Cognito User Pool ID (e.g., us-east-1_xxxxxxxxx)
VITE_COGNITO_USER_POOL_ID=

# Your Cognito App Client ID (e.g., 7xxxxxxxxxxxxxxxxxxxxxxxx)
VITE_COGNITO_CLIENT_ID=
